<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/poseReferenceImage"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/pose_reference_image"
            android:scaleType="centerCrop"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/selectionOverlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="#2200BCD4"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/poseReferenceImage"
            app:layout_constraintEnd_toEndOf="@id/poseReferenceImage"
            app:layout_constraintStart_toStartOf="@id/poseReferenceImage"
            app:layout_constraintTop_toTopOf="@id/poseReferenceImage" />

        <TextView
            android:id="@+id/poseReferenceName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="#99000000"
            android:paddingStart="8dp"
            android:paddingTop="4dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/poseReferenceImage"
            app:layout_constraintEnd_toEndOf="@id/poseReferenceImage"
            app:layout_constraintStart_toStartOf="@id/poseReferenceImage" />

        <ImageButton
            android:id="@+id/deletePoseReference"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_margin="6dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/delete_pose_reference"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="@android:color/white"
            app:layout_constraintStart_toStartOf="@id/poseReferenceImage"
            app:layout_constraintTop_toTopOf="@id/poseReferenceImage" />

        <TextView
            android:id="@+id/passwordStepBadge"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_margin="6dp"
            android:background="@drawable/bg_password_step_badge"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@id/poseReferenceImage"
            app:layout_constraintTop_toTopOf="@id/poseReferenceImage" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
